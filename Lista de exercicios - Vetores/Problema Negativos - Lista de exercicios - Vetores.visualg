algoritmo "Problema Negativos"

var

  n, i : inteiro
  vet : vetor[0 .. 9] de inteiro

inicio

  escreval("Quantos números você vai digitar?: ")
  leia(n)

  para i de 0 ate n-1 faca

    escreval("Digite um número: ")
    leia(vet[i])
  fimpara

  escreval("NÚMEROS NEGATIVOS: ")

  para i de 0 ate n-1 faca

    se vet[i] < 0 entao
    
      escreval(vet[i])
    fimse
  fimpara

fimalgoritmo