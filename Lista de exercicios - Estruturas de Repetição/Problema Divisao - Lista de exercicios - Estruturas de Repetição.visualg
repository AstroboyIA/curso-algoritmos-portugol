algoritmo "Problema Divisão"

var

  n, i : inteiro
  n1, n2, n3, divisao : real

inicio

  escreval("Quantos casos você vai digitar?: ")
  leia(n)

  para i de 1 ate N faca

    Escreval("Entre com o numerador: ")
    leia(n1)
    Escreval("Entre com o denominador: ")
    leia(n2)

    se n2 = 0 entao

      escreval("DIVISAO IMPOSSIVEL")

    senao

      divisao <- n1 / n2

      escreval("DIVISÃO = ", divisao:1:2)

    fimse

  fimpara

fimalgoritmo