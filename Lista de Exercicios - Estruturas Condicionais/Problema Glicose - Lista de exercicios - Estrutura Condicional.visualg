algoritmo "Problema Glicose"

var

  glicose : real

inicio

  escreval("Digite a medida da glicose: ")
  leia(glicose)

  se glicose <= 100 entao

    escreval("Classificação: Normal")

  senao se glicose <= 140 entao

    escreval("Classificação: Elevado")

  senao

    escreval("Classificação: Diabetes")

  fimse

fimse

fimalgoritmo